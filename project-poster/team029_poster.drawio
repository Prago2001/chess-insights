          <mxGeometry height="12" width="3000" y="320" as="geometry" />
        </mxCell>
        <mxCell id="icon_l" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=100;fontColor=#ffd600;align=center;verticalAlign=middle;" value="♛" vertex="1">
