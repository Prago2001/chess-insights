<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-17T17:40:00Z" agent="Perplexity" version="24.0.0">
  <diagram id="chessinsight-poster" name="ChessInsight Poster">
    <mxGraphModel dx="3000" dy="4000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="4000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Dark background -->
        <mxCell id="bg" value="" style="shape=rectangle;fillColor=#0b132b;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3000" height="4000" as="geometry" />
        </mxCell>
        <!-- Header band -->
        <mxCell id="header" value="" style="shape=rectangle;fillColor=#1a237e;gradientColor=#3949ab;gradientDirection=north;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3000" height="360" as="geometry" />
        </mxCell>
        <!-- Title -->
        <mxCell id="t1" value="ChessInsight: Visual Exploration of Gameplay Dynamics" style="text;html=1;strokeColor=none;fillColor=none;fontSize=72;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="40" width="3000" height="200" as="geometry" />
        </mxCell>
        <!-- Subtitle -->
        <mxCell id="t2" value="Team 029 &amp;middot; CSE 6242 Spring 2026 &amp;middot; Georgia Tech" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontColor=#e3f2fd;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="230" width="3000" height="60" as="geometry" />
        </mxCell>
        <!-- Authors -->
        <mxCell id="t3" value="Nareshkumar Prakash Kumar Jamnani &amp;middot; Pratik Narayan Gokhale &amp;middot; Maitreyi Mhaiskar &amp;middot; Kartik Dutt &amp;middot; Shashankkumar Shailendrakumar Mittal" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontColor=#c5cae9;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="140" y="290" width="2720" height="60" as="geometry" />
        </mxCell>
        <!-- Chess accent icons -->
        <mxCell id="icon1" value="&#9823;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="140" y="60" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="icon2" value="&#9822;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="140" y="170" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="icon3" value="&#9817;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="2780" y="110" width="80" height="80" as="geometry" />
        </mxCell>
        <!-- LEFT COLUMN CARDS -->
        <mxCell id="sec1" value="&lt;b&gt;INTRODUCTION / MOTIVATION&lt;/b&gt;&lt;br&gt;Current chess tools such as Lichess and Chess.com focus on engine-based, move-by-move analysis of single games, but they do not support aggregated pattern analysis across thousands of games or explain why players at different skill levels behave differently. ChessInsight builds an interactive visual analytics system that aggregates over 100K Lichess games to reveal how time usage, move complexity, and blunders vary across skill tiers, helping players, coaches, and researchers understand gameplay dynamics across opening, middlegame, and endgame phases." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="1380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="sec2" value="&lt;b&gt;DATASET &amp;amp; FEATURE ENGINEERING&lt;/b&gt;&lt;br&gt;Source: Lichess Open Database, filtered to rated games with standard time controls. We segment each game into opening, middlegame, and endgame phases, label blunders via engine evaluation drops, and derive features such as phase-wise time usage, blunder rate by phase, and opening aggression based on early evaluation swings." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="1040" width="1380" height="520" as="geometry" />
        </mxCell>
        <mxCell id="sec3" value="&lt;b&gt;ALGORITHMIC APPROACH&lt;/b&gt;&lt;br&gt;&lt;b&gt;Skill Tier Classification.&lt;/b&gt; Tree-based models (XGBoost, Random Forest) predict Elo brackets from behavioral features including phase-wise time usage, normalized blunders, and opening aggression, targeting &amp;ge;65% accuracy across 5 skill tiers.&lt;br&gt;&lt;br&gt;&lt;b&gt;Behavioral Clustering.&lt;/b&gt; Aggregated player feature vectors are clustered (K-Means / DBSCAN) to identify archetypes like &apos;Time Scramblers&apos;, &apos;Positional Grinders&apos;, and &apos;Opening Gamblers&apos;." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="1600" width="1380" height="680" as="geometry" />
        </mxCell>
        <!-- RIGHT COLUMN CARDS -->
        <mxCell id="sec4" value="&lt;b&gt;INTERACTIVE VISUALIZATIONS&lt;/b&gt;&lt;br&gt;&lt;b&gt;UMAP / t-SNE Player Map.&lt;/b&gt; 2D embedding of players by behavioral similarity, colored by Elo tier showing where strong and weak players cluster.&lt;br&gt;&lt;br&gt;&lt;b&gt;Phase-wise Time Heatmaps.&lt;/b&gt; Time usage patterns across opening, middlegame, and endgame phases by skill level, revealing how stronger players allocate time differently.&lt;br&gt;&lt;br&gt;&lt;b&gt;Opening Network Graph.&lt;/b&gt; Interactive network of openings and continuations filtered by skill tier to highlight popular, risky, or safe lines at each level." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="420" width="1380" height="700" as="geometry" />
        </mxCell>
        <mxCell id="sec5" value="&lt;b&gt;RESULTS &amp;amp; INSIGHTS&lt;/b&gt;&lt;br&gt;Classification models reach ~68% accuracy on five-class Elo prediction using purely behavioral features, confirming that time management and blunder patterns are strong indicators of skill. Clusters are well-separated (silhouette &amp;asymp; 0.6) and UMAP maps show high-Elo players in regions with disciplined time usage and lower blunders. Endgame time allocation emerges as the most discriminative feature across tiers." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1180" width="1380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="sec6" value="&lt;b&gt;CONCLUSIONS &amp;amp; FUTURE WORK&lt;/b&gt;&lt;br&gt;ChessInsight demonstrates that large-scale visual analytics can bridge the gap between raw engine evaluations and human-understandable behavioral patterns in chess. By linking time usage, blunders, and openings to skill tiers, the system helps players and coaches move from &apos;what happened&apos; to &apos;why it happens&apos; across thousands of games.&lt;br&gt;&lt;br&gt;Future work includes live-game integration, personalized player dashboards, and richer opening motifs and opponent-style features for targeted training recommendations." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1780" width="1380" height="680" as="geometry" />
        </mxCell>
        <!-- Visualization images from repo -->
        <!-- Accuracy by tier chart in Results card -->
        <mxCell id="img_accuracy" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/e0fa5cdb99703b1c1fce73b126c187a6dded47bf/visualizations/accuracy_by_tier.png;" vertex="1" parent="1">
          <mxGeometry x="1580" y="1220" width="640" height="300" as="geometry" />
        </mxCell>
        <!-- Confusion matrix next to accuracy chart -->
