          <mxGeometry x="2240" y="1220" width="640" height="300" as="geometry" />
        </mxCell>
        <!-- Time heatmap under Interactive Visualizations -->
        <mxCell id="img_time_heatmap" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/e0fa5cdb99703b1c1fce73b126c187a6dded47bf/visualizations/time_heatmap.png;" vertex="1" parent="1">
          <mxGeometry x="1580" y="760" width="640" height="300" as="geometry" />
        </mxCell>
        <!-- Cluster embedding scatter plot below header of visualizations -->
        <mxCell id="img_cluster_embedding" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/e0fa5cdb99703b1c1fce73b126c187a6dded47bf/visualizations/cluster_embedding.png;" vertex="1" parent="1">
          <mxGeometry x="2240" y="760" width="640" height="300" as="geometry" />
        </mxCell>
        <!-- Footer -->
        <mxCell id="footer" value="Data: Lichess Open Database &amp;middot; Tools: Python, Streamlit, Plotly, scikit-learn, Stockfish &amp;middot; GitHub: github.com/Prago2001/chess-insights" style="text;html=1;strokeColor=none;fillColor=none;fontSize=18;fontColor=#e3f2fd;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="3880" width="3000" height="80" as="geometry" />
        </mxCell>
      </root>
