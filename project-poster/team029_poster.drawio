        <mxCell id="img_accuracy" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/accuracy_by_tier.png;" vertex="1" parent="1">
          <mxGeometry x="1580" y="1180" width="640" height="320" as="geometry" />
        </mxCell>
        <mxCell id="img_confusion" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/confusion_matrix.png;" vertex="1" parent="1">
          <mxGeometry x="2240" y="1180" width="640" height="320" as="geometry" />
        </mxCell>
        <mxCell id="img_cluster_characteristics" value="" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/cluster_characteristics.png;" vertex="1" parent="1">
          <mxGeometry x="1580" y="1520" width="640" height="320" as="geometry" />
        </mxCell>
        <!-- Footer -->
        <mxCell id="footer" value="Data: Lichess Open Database &amp;middot; Tools: Python, Streamlit, Plotly, scikit-learn, XGBoost, Stockfish &amp;middot; GitHub: github.com/Prago2001/chess-insights" style="text;html=1;strokeColor=none;fillColor=none;fontSize=18;fontColor=#e3f2fd;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="3880" width="3000" height="80" as="geometry" />
        </mxCell>
      </root>
