  <diagram id="chessinsight-poster" name="ChessInsight Poster">
    <mxGraphModel dx="8216" dy="4608" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="3000" pageHeight="4000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
