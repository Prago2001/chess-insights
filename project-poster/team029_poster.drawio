        </mxCell>
        <mxCell id="icon_r" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=100;fontColor=#ffd600;align=center;verticalAlign=middle;" value="♕" vertex="1">
          <mxGeometry height="200" width="200" x="2740" y="60" as="geometry" />
        </mxCell>
        <mxCell id="t1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=74;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="ChessInsight: Visual Exploration of Gameplay Dynamics" vertex="1">
          <mxGeometry height="160" width="2440" x="280" y="30" as="geometry" />
        </mxCell>
        <mxCell id="t2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=32;fontColor=#ffd600;align=center;verticalAlign=middle;fontStyle=1;" value="Team 029 &amp;nbsp;&amp;middot;&amp;nbsp; CSE 6242 Spring 2026 &amp;nbsp;&amp;middot;&amp;nbsp; Georgia Tech" vertex="1">
          <mxGeometry height="60" width="2440" x="280" y="185" as="geometry" />
        </mxCell>
        <mxCell id="t3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=22;fontColor=#c5cae9;align=center;verticalAlign=middle;" value="Nareshkumar Prakash Kumar Jamnani &amp;nbsp;&amp;middot;&amp;nbsp; Pratik Narayan Gokhale &amp;nbsp;&amp;middot;&amp;nbsp; Maitreyi Mhaiskar &amp;nbsp;&amp;middot;&amp;nbsp; Kartik Dutt &amp;nbsp;&amp;middot;&amp;nbsp; Shashankkumar Shailendrakumar Mittal" vertex="1">
          <mxGeometry height="60" width="2800" x="100" y="252" as="geometry" />
        </mxCell>
        <mxCell id="hdr_mot" parent="1" style="text;html=1;strokeColor=none;fillColor=#1a237e;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;MOTIVATION &amp;amp; PROBLEM" vertex="1">
          <mxGeometry height="56" width="900" x="60" y="360" as="geometry" />
        </mxCell>
        <mxCell id="sec_mot" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#ffffff;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=22;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;What is the problem?&lt;/b&gt;&lt;br/&gt;Tools like Lichess and Chess.com analyse one game at a time via engine evaluation. They cannot reveal &lt;i&gt;population-level patterns&lt;/i&gt; — how 350 K games worth of time usage, blunder rates, and position complexity differ across skill tiers.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Why does it matter?&lt;/b&gt;&lt;br/&gt;Players, coaches, and researchers lack a visual system to understand &lt;i&gt;why&lt;/i&gt; stronger players behave differently — e.g., how they allocate time across opening / middlegame / endgame or recover from time pressure.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Our goal&lt;/b&gt;&lt;br/&gt;Build an &lt;b&gt;interactive visual analytics dashboard&lt;/b&gt; that:&lt;br/&gt;• Predicts skill tier from &lt;i&gt;behavioral&lt;/i&gt; features (not raw Elo)&lt;br/&gt;• Clusters players into interpretable behavioral archetypes&lt;br/&gt;• Lets users explore patterns through linked, filterable views" vertex="1">
          <mxGeometry height="680" width="900" x="60" y="420" as="geometry" />
        </mxCell>
        <mxCell id="hdr_dat" parent="1" style="text;html=1;strokeColor=none;fillColor=#1a237e;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;DATASET &amp;amp; FEATURES" vertex="1">
          <mxGeometry height="56" width="900" x="1050" y="360" as="geometry" />
        </mxCell>
        <mxCell id="sec_dat" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#ffffff;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=22;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;Source:&lt;/b&gt; Lichess Open Database (data_1m_games.pgn)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Scale:&lt;/b&gt;&lt;br/&gt;• &lt;b&gt;350,060&lt;/b&gt; rapid / classical games&lt;br/&gt;• &lt;b&gt;238,200&lt;/b&gt; unique players in raw PGN&lt;br/&gt;• &lt;b&gt;22,725&lt;/b&gt; players with stable behavioral vectors (&amp;ge;5 games)&lt;br/&gt;• Elo range: &lt;b&gt;600 – 3,265&lt;/b&gt; (beginner → titled)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Game-level features (47):&lt;/b&gt;&lt;br/&gt;• Phase-wise avg. move time &amp;amp; time variance (opening / middlegame / endgame)&lt;br/&gt;• Time-pressure frequency, low-time move ratio&lt;br/&gt;• Centipawn loss, blunder &amp;amp; mistake rates&lt;br/&gt;• Position complexity, opening aggression, piece activity&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Player-level features (39):&lt;/b&gt;&lt;br/&gt;• Aggregated means, variances, and derived ratios per player&lt;br/&gt;• Time-accuracy interaction, error-severity score" vertex="1">
          <mxGeometry height="680" width="900" x="1050" y="420" as="geometry" />
        </mxCell>
        <mxCell id="hdr_meth" parent="1" style="text;html=1;strokeColor=none;fillColor=#1a237e;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;METHODS" vertex="1">
          <mxGeometry height="56" width="900" x="2040" y="360" as="geometry" />
        </mxCell>
        <mxCell id="sec_meth" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#ffffff;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=22;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;Task 1 — Skill-Tier Classification&lt;/b&gt;&lt;br/&gt;Predict 4 tiers (Beginner / Intermediate / Advanced / Expert) from behavioral features — not Elo.&lt;br/&gt;&lt;br/&gt;• Models: Random Forest, XGBoost, soft-voting Ensemble&lt;br/&gt;• SMOTE + class-weighted loss for imbalance&lt;br/&gt;• Engineered features: phase-time ratios, time-pressure score, complexity–time interaction, error-severity&lt;br/&gt;• Split: 230 K train / 49 K val / 49 K test&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Task 2 — Behavioral Clustering&lt;/b&gt;&lt;br/&gt;Discover recurring player archetypes without using Elo as a label.&lt;br/&gt;&lt;br/&gt;• Algorithms: K-Means, BIRCH, Gaussian Mixture&lt;br/&gt;• Sweep k = 3–7; select via Silhouette, Calinski–Harabasz, Davies–Bouldin&lt;br/&gt;• Chosen: BIRCH, k = 5&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Dashboard (Streamlit)&lt;/b&gt;&lt;br/&gt;• 2-D player map (PCA/t-SNE), phase-time heatmap, cluster archetype panels, confusion matrix — all linked by filters" vertex="1">
          <mxGeometry height="680" width="900" x="2040" y="420" as="geometry" />
        </mxCell>
        <mxCell id="div1" parent="1" style="shape=rectangle;fillColor=#1a237e;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="8" width="3000" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="hdr_viz" parent="1" style="text;html=1;strokeColor=none;fillColor=#283593;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;INTERACTIVE VISUALIZATIONS" vertex="1">
          <mxGeometry height="56" width="2880" x="60" y="1148" as="geometry" />
        </mxCell>
        <mxCell id="viz1_card" parent="1" style="rounded=1;shadow=0;strokeColor=#283593;strokeWidth=2;fillColor=#e8eaf6;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=21;align=left;verticalAlign=top;spacingTop=16;spacingLeft=16;spacingRight=16;" value="&lt;b&gt;■ Skill Distribution&lt;/b&gt;&lt;br/&gt;Bar chart of game counts across Beginner / Intermediate / Advanced / Expert tiers. Advanced dominates (124 K games), while Beginner is the smallest class (42 K). This class imbalance motivates SMOTE resampling in the classifier." vertex="1">
          <mxGeometry height="220" width="900" x="60" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="viz2_card" parent="1" style="rounded=1;shadow=0;strokeColor=#283593;strokeWidth=2;fillColor=#e8eaf6;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=21;align=left;verticalAlign=top;spacingTop=16;spacingLeft=16;spacingRight=16;" value="&lt;b&gt;■ Phase-wise Time Heatmap&lt;/b&gt;&lt;br/&gt;Heatmap of average seconds-per-move by skill tier × game phase. Stronger players invest proportionally more time in the middlegame; beginners often burn time early or move impulsively under pressure." vertex="1">
          <mxGeometry height="220" width="900" x="1050" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="viz3_card" parent="1" style="rounded=1;shadow=0;strokeColor=#283593;strokeWidth=2;fillColor=#e8eaf6;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=21;align=left;verticalAlign=top;spacingTop=16;spacingLeft=16;spacingRight=16;" value="&lt;b&gt;■ Player Behavior Map&lt;/b&gt;&lt;br/&gt;2-D t-SNE / PCA scatter of 22 K players colored by cluster archetype. Reveals that behavioral similarity does not always align with Elo — some low-rated players cluster with higher-rated ones due to disciplined time management." vertex="1">
          <mxGeometry height="220" width="900" x="2040" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="img1" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/skill_distribution.png;rounded=1;strokeColor=#283593;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="900" x="60" y="1456" as="geometry" />
        </mxCell>
        <mxCell id="img2" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/time_heatmap.png;rounded=1;strokeColor=#283593;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="900" x="1050" y="1456" as="geometry" />
        </mxCell>
        <mxCell id="img3" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/cluster_embedding.png;rounded=1;strokeColor=#283593;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="900" x="2040" y="1456" as="geometry" />
        </mxCell>
        <mxCell id="div2" parent="1" style="shape=rectangle;fillColor=#1a237e;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="8" width="3000" y="1996" as="geometry" />
        </mxCell>
        <mxCell id="hdr_res" parent="1" style="text;html=1;strokeColor=none;fillColor=#00695c;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;RESULTS" vertex="1">
          <mxGeometry height="56" width="2880" x="60" y="2024" as="geometry" />
        </mxCell>
        <mxCell id="img4" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/accuracy_by_tier.png;rounded=1;strokeColor=#00695c;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="930" x="60" y="2100" as="geometry" />
        </mxCell>
        <mxCell id="img5" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/confusion_matrix.png;rounded=1;strokeColor=#00695c;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="930" x="1010" y="2100" as="geometry" />
        </mxCell>
        <mxCell id="img6" parent="1" style="shape=image;html=1;imageAspect=1;image=https://raw.githubusercontent.com/Prago2001/chess-insights/main/visualizations/cluster_characteristics.png;rounded=1;strokeColor=#00695c;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="520" width="980" x="1960" y="2100" as="geometry" />
        </mxCell>
        <mxCell id="kpi1" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#e8eaf6;html=1;align=center;verticalAlign=middle;spacingTop=10;" value="&lt;font style=&quot;font-size:52px;font-weight:bold;color:#1a237e;&quot;&gt;44.5%&lt;/font&gt;&lt;br/&gt;&lt;span style=&quot;font-size:22px;color:#424242;&quot;&gt;Exact-Tier Test Accuracy&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:18px;color:#757575;&quot;&gt;XGBoost · 4-class · chance = 25%&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="590" x="60" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="kpi2" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#e8eaf6;html=1;align=center;verticalAlign=middle;spacingTop=10;" value="&lt;font style=&quot;font-size:52px;font-weight:bold;color:#1a237e;&quot;&gt;55.6%&lt;/font&gt;&lt;br/&gt;&lt;span style=&quot;font-size:22px;color:#424242;&quot;&gt;Adjacent-Tier Accuracy&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:18px;color:#757575;&quot;&gt;Predictions within ±1 tier&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="590" x="670" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="kpi3" parent="1" style="rounded=1;shadow=0;strokeColor=#1a237e;strokeWidth=3;fillColor=#e8eaf6;html=1;align=center;verticalAlign=middle;spacingTop=10;" value="&lt;font style=&quot;font-size:52px;font-weight:bold;color:#1a237e;&quot;&gt;0.44&lt;/font&gt;&lt;br/&gt;&lt;span style=&quot;font-size:22px;color:#424242;&quot;&gt;Macro F1 Score&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:18px;color:#757575;&quot;&gt;Balanced across all tiers&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="590" x="1280" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="kpi4" parent="1" style="rounded=1;shadow=0;strokeColor=#00695c;strokeWidth=3;fillColor=#e0f2f1;html=1;align=center;verticalAlign=middle;spacingTop=10;" value="&lt;font style=&quot;font-size:52px;font-weight:bold;color:#00695c;&quot;&gt;0.296&lt;/font&gt;&lt;br/&gt;&lt;span style=&quot;font-size:22px;color:#424242;&quot;&gt;Silhouette Score (BIRCH k=5)&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:18px;color:#757575;&quot;&gt;Moderate cluster separation&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="590" x="1890" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="kpi5" parent="1" style="rounded=1;shadow=0;strokeColor=#00695c;strokeWidth=3;fillColor=#e0f2f1;html=1;align=center;verticalAlign=middle;spacingTop=10;" value="&lt;font style=&quot;font-size:52px;font-weight:bold;color:#00695c;&quot;&gt;5&lt;/font&gt;&lt;br/&gt;&lt;span style=&quot;font-size:22px;color:#424242;&quot;&gt;Behavioral Archetypes&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:18px;color:#757575;&quot;&gt;Solid · Deliberate · Fast · Specialist · Elite&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="440" x="2500" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="res_text" parent="1" style="rounded=1;shadow=0;strokeColor=#00695c;strokeWidth=2;fillColor=#ffffff;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=21;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;Skill Classification:&lt;/b&gt; XGBoost achieves 44.5% exact-tier and 55.6% adjacent-tier test accuracy — well above the 25% random baseline for a 4-class task. Macro F1 ≈ 0.44 confirms balanced performance across tiers. The most important features are &lt;i&gt;middlegame avg. move time&lt;/i&gt; (0.16), &lt;i&gt;opening time variance&lt;/i&gt; (0.12), and &lt;i&gt;position complexity&lt;/i&gt; (0.10). Most misclassifications occur between adjacent tiers (Intermediate ↔ Advanced, Advanced ↔ Expert), showing the model has learned a sensible skill ordering.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Behavioral Clustering:&lt;/b&gt; BIRCH with k = 5 yields silhouette = 0.296, CH-index = 1826, DB-index = 1.04 — the best trade-off across methods tested. Five distinct archetypes emerge: &lt;b&gt;Solid Advanced Core&lt;/b&gt; (21 K players, avg. Elo 1714), &lt;b&gt;Deliberate Intermediates&lt;/b&gt; (1.6 K, avg. Elo 1505), &lt;b&gt;High-Level Deliberate Specialists&lt;/b&gt; (74 players, avg. Elo 1780), &lt;b&gt;Fast Advanced Grinders&lt;/b&gt; (3 players), and an &lt;b&gt;Elite Expert&lt;/b&gt; outlier (avg. Elo 2119)." vertex="1">
          <mxGeometry height="300" width="2880" x="60" y="2860" as="geometry" />
        </mxCell>
        <mxCell id="div3" parent="1" style="shape=rectangle;fillColor=#1a237e;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="8" width="3000" y="3178" as="geometry" />
        </mxCell>
        <mxCell id="hdr_con" parent="1" style="text;html=1;strokeColor=none;fillColor=#4527a0;fontSize=28;fontStyle=1;fontColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=20;rounded=1;" value="▲ &amp;nbsp;CONCLUSIONS &amp;amp; FUTURE WORK" vertex="1">
          <mxGeometry height="56" width="2880" x="60" y="3206" as="geometry" />
        </mxCell>
        <mxCell id="sec_con" parent="1" style="rounded=1;shadow=0;strokeColor=#4527a0;strokeWidth=3;fillColor=#ede7f6;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=22;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;Conclusions&lt;/b&gt;&lt;br/&gt;• ChessInsight scales behavioral analysis to &lt;b&gt;350 K games&lt;/b&gt; and &lt;b&gt;22 K players&lt;/b&gt;, far beyond what any single-game engine can show.&lt;br/&gt;• Time management — specifically phase-wise move-time allocation — is the &lt;b&gt;strongest behavioral predictor of skill&lt;/b&gt;, outweighing blunder rates and piece activity.&lt;br/&gt;• Exact-tier accuracy of 44.5% and adjacent accuracy of 55.6% confirm that behavioral features carry significant, but partial, skill signal. There is genuine ambiguity at tier boundaries.&lt;br/&gt;• BIRCH clustering reveals &lt;b&gt;5 interpretable archetypes&lt;/b&gt;, demonstrating that multiple behavioral pathways lead to similar Elo — coaching is not one-size-fits-all.&lt;br/&gt;• The Streamlit dashboard connects all components into a single interactive experience for players, coaches, and researchers." vertex="1">
          <mxGeometry height="580" width="1380" x="60" y="3278" as="geometry" />
        </mxCell>
        <mxCell id="sec_fut" parent="1" style="rounded=1;shadow=0;strokeColor=#4527a0;strokeWidth=3;fillColor=#ede7f6;fontColor=#212121;html=1;whiteSpace=wrap;fontSize=22;align=left;verticalAlign=top;spacingTop=20;spacingLeft=20;spacingRight=20;spacingBottom=20;" value="&lt;b&gt;Limitations&lt;/b&gt;&lt;br/&gt;• Tier boundaries are soft: Intermediate ↔ Advanced confusion is high.&lt;br/&gt;• Cluster sizes are highly unequal; smallest clusters have &lt; 5 players and cannot be reliably interpreted.&lt;br/&gt;• Analysis limited to games with reliable clock data — blitz omitted.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Future Work&lt;/b&gt;&lt;br/&gt;• Add &lt;b&gt;move-by-move time series&lt;/b&gt; features and opening-family behavioral signatures.&lt;br/&gt;• Explore semi-supervised and density-based clustering to stabilize archetypes.&lt;br/&gt;• Calibrate predicted skill tier against future rating gain as a longitudinal ground truth.&lt;br/&gt;• Deploy dashboard publicly on Lichess game histories and conduct user studies to measure coaching impact." vertex="1">
          <mxGeometry height="580" width="1380" x="1560" y="3278" as="geometry" />
        </mxCell>
        <mxCell id="footer_bg" parent="1" style="shape=rectangle;fillColor=#1a237e;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="100" width="3000" y="3900" as="geometry" />
        </mxCell>
        <mxCell id="footer" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=22;fontColor=#e3f2fd;align=center;verticalAlign=middle;" value="Data: Lichess Open Database &amp;nbsp;·&amp;nbsp; Tools: Python, Streamlit, Plotly, scikit-learn, XGBoost, Stockfish &amp;nbsp;·&amp;nbsp;" vertex="1">
          <mxGeometry height="100" width="3000" y="3900" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
