<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-18T12:00:00Z" agent="Perplexity" version="24.0.0">
  <diagram id="chessinsight-poster" name="ChessInsight Poster">
    <mxGraphModel dx="3000" dy="4000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="4000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Dark background -->
        <mxCell id="bg" value="" style="shape=rectangle;fillColor=#0b132b;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3000" height="4000" as="geometry" />
        </mxCell>
        <!-- Header band -->
        <mxCell id="header" value="" style="shape=rectangle;fillColor=#1a237e;gradientColor=#3949ab;gradientDirection=north;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3000" height="360" as="geometry" />
        </mxCell>
        <!-- Title -->
        <mxCell id="t1" value="ChessInsight: Visual Exploration of Gameplay Dynamics" style="text;html=1;strokeColor=none;fillColor=none;fontSize=72;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="40" width="3000" height="200" as="geometry" />
        </mxCell>
        <!-- Subtitle -->
        <mxCell id="t2" value="Team 029 &amp;middot; CSE 6242 Spring 2026 &amp;middot; Georgia Tech" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontColor=#e3f2fd;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="230" width="3000" height="60" as="geometry" />
        </mxCell>
        <!-- Authors -->
        <mxCell id="t3" value="Nareshkumar Prakash Kumar Jamnani &amp;middot; Pratik Narayan Gokhale &amp;middot; Maitreyi Mhaiskar &amp;middot; Kartik Dutt &amp;middot; Shashankkumar Shailendrakumar Mittal" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontColor=#c5cae9;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="140" y="290" width="2720" height="60" as="geometry" />
        </mxCell>
        <!-- Chess accent icons -->
        <mxCell id="icon1" value="&#9823;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="140" y="60" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="icon2" value="&#9822;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="140" y="170" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="icon3" value="&#9817;" style="text;html=1;shape=ellipse;align=center;verticalAlign=middle;fontSize=26;fontColor=#ffffff;fillColor=#3949ab;strokeColor=#bbdefb;" vertex="1" parent="1">
          <mxGeometry x="2780" y="110" width="80" height="80" as="geometry" />
        </mxCell>
        <!-- LEFT COLUMN CARDS -->
        <mxCell id="sec1" value="&lt;b&gt;INTRODUCTION / MOTIVATION&lt;/b&gt;&lt;br&gt;Current chess tools such as Lichess and Chess.com focus on engine-based, move-by-move analysis of single games, but they do not support aggregated pattern analysis across thousands of games or explain why players at different Elo tiers behave differently. ChessInsight builds an interactive visual analytics system over 350K+ Lichess games, revealing how time usage, blunders, and position complexity vary across opening, middlegame, and endgame phases." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="1380" height="520" as="geometry" />
        </mxCell>
        <mxCell id="sec2" value="&lt;b&gt;DATASET&lt;/b&gt;&lt;br&gt;• Source: Lichess Open Database &amp;mdash; 350,060 rapid/classical games after cleaning.&lt;br&gt;• Players: 22,725 players with aggregated behavioral vectors (min. 5 games each).&lt;br&gt;• Rating range: Elo 600&amp;ndash;3265 spanning beginners to titled players.&lt;br&gt;• Features: 39 game-level and 30 player-level features capturing phase-wise time usage, time-pressure frequency, centipawn loss, blunder/mistake rates, opening aggression, and piece activity.&lt;br&gt;• Preprocessing: PGN parsing, phase segmentation, Stockfish-based blunder labels, and aggregation at player level." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="980" width="1380" height="640" as="geometry" />
        </mxCell>
        <mxCell id="sec3" value="&lt;b&gt;ALGORITHMS &amp;amp; METHODS&lt;/b&gt;&lt;br&gt;&lt;b&gt;Skill Tier Classification.&lt;/b&gt; Tree-based models (Random Forest, XGBoost, soft-voting ensemble) predict 4 Elo tiers (Beginner, Intermediate, Advanced, Expert) from behavioral features alone. We apply SMOTE and class-weighted loss to counter class imbalance, and engineer ratios (time distribution across phases, error rates per 40 moves, complexity–time interactions).&lt;br&gt;&lt;br&gt;&lt;b&gt;Behavioral Clustering.&lt;/b&gt; Player-level vectors are standardized and clustered into archetypes using K-Means/BIRCH over PCA-reduced or full feature space. We sweep k = 3&amp;ndash;5 and compare methods via silhouette, Calinski&amp;ndash;Harabasz, and Davies&amp;ndash;Bouldin scores, selecting well-separated yet interpretable archetypes (e.g., &quot;Deliberate Intermediates&quot;, &quot;Fast Advanced Grinders&quot;)." style="rounded=1;glass=0;shadow=1;strokeColor=#1a237e;strokeWidth=2;fillColor=#e8eaf6;fontColor=#0b132b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="1660" width="1380" height="820" as="geometry" />
        </mxCell>
        <!-- RIGHT COLUMN CARDS -->
        <mxCell id="sec4" value="&lt;b&gt;INTERACTIVE VISUALIZATIONS&lt;/b&gt;&lt;br&gt;• UMAP/t-SNE Player Map: 2D scatter of players by behavioral similarity, colored by Elo tier and cluster.&lt;br&gt;• Phase-wise Time Heatmap: Time usage patterns across opening/middlegame/endgame by tier, highlighting disciplined time management of stronger players.&lt;br&gt;• Skill Distribution &amp;amp; Confusion Matrix: Overview of class balance and where the classifier confuses adjacent tiers.&lt;br&gt;• Cluster Archetype Panels: For each archetype, show average Elo, time allocation, and blunder rates, enabling side-by-side comparison of styles." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="420" width="1380" height="640" as="geometry" />
        </mxCell>
        <mxCell id="sec5" value="&lt;b&gt;RESULTS&lt;/b&gt;&lt;br&gt;&lt;b&gt;Skill Tier Classification.&lt;/b&gt; XGBoost and Random Forest baselines reach ~44% exact-tier test accuracy and ~55% adjacent-tier accuracy (±1 tier), substantially above chance for a 4-class problem but leaving room for improvement. Macro F1 is ~0.44, indicating balanced performance across tiers. Time usage and position complexity dominate feature importance, confirming that when and where players think is as important as what they play.&lt;br&gt;&lt;br&gt;&lt;b&gt;Behavioral Clustering.&lt;/b&gt; Initial 4-cluster K-Means with PCA yielded one giant cluster (&gt;99% of players). We address this by scanning k = 3&amp;ndash;5, trying K-Means without PCA and BIRCH, and choosing configurations with both reasonable silhouette (&gt;0.18) and non-degenerate cluster sizes. The selected setting produces multiple mid-sized archetype clusters with distinct time-management and blunder profiles rather than one dominating group." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1120" width="1380" height="760" as="geometry" />
        </mxCell>
        <mxCell id="sec6" value="&lt;b&gt;CONCLUSIONS &amp;amp; FUTURE WORK&lt;/b&gt;&lt;br&gt;ChessInsight demonstrates that large-scale visual analytics can bridge the gap between engine evaluations and human-understandable patterns. Behavioral features like phase-wise time usage and blunder rates are strong but imperfect proxies for skill; our current models achieve moderate accuracy and reveal interpretable failure modes (especially between Intermediate and Advanced tiers). Clustering uncovers diverse archetypes rather than a single &quot;best&quot; style, suggesting multiple pathways to improvement.&lt;br&gt;&lt;br&gt;Next steps include richer temporal features (move-by-move time series), opening-specific behavior, calibration of predicted skill tiers against future rating gain, and deploying the dashboard to provide personalized coaching recommendations directly on top of Lichess game histories." style="rounded=1;glass=0;shadow=1;strokeColor=#004d40;strokeWidth=2;fillColor=#e0f2f1;fontColor=#00332b;text;html=1;whiteSpace=wrap;fontSize=20;align=left;verticalAlign=top;spacingTop=18;spacingLeft=18;spacingRight=18;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1920" width="1380" height="760" as="geometry" />
        </mxCell>
